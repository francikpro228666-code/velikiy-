# Разрешаем доступ к этой папке и всем её подпапкам (Apache 2.4+)
Require all granted

# Включаем механизм перезаписи URL
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Если вы запускаете через php -S localhost:8000 -t public, 
    # то RewriteEngine не работает (нужен Apache)
    # Поэтому эту строку можно закомментировать или удалить
    # RewriteBase /

    # Если файл реально существует (CSS, JS, картинки) – отдаём напрямую
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Перенаправляем всё остальное в index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Защита от просмотра папок
Options -Indexes

# Защита от доступа к скрытым файлам
RedirectMatch 403 /\..*$